# Create a Supabase project, apply the migrations in /supabase/migrations,
# deploy the functions in /supabase/functions, and copy the public client
# values from Project Settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Optional: enables the location visualization in the mood dashboard.
VITE_MAPBOX_TOKEN=
